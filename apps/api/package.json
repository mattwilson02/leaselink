{
	"name": "@leaselink/api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"dev": "npx dotenv -e .env.local -- nest start --watch",
		"format": "npx @biomejs/biome format --write .",
		"start": "npx dotenv -e .env.local -- nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "npx biome check ./src --write",
		"db:create": "docker-compose -f docker-compose.postgres.yaml up -d",
		"db:drop": "docker-compose -f docker-compose.postgres.yaml down",
		"db:stop": "docker-compose -f docker-compose.postgres.yaml stop",
		"db:restart": "docker-compose -f docker-compose.postgres.yaml restart",
		"db:logs": "docker-compose -f docker-compose.postgres.yaml logs -f",
		"db:seed": "npx prisma db seed",
		"db:reset": "npx prisma migrate reset --force",
		"db:setup": "npm run db:create && npm run db:migrate dev && npm run db:seed",
		"db:studio": "npx prisma studio",
		"db:migrate": "npx prisma migrate dev",
		"db:migrate:deploy": "npx prisma migrate deploy && npx prisma db seed",
		"azurite:start": "docker compose -f docker-compose.azurite.yaml up -d",
		"azurite:stop": "docker compose -f docker-compose.azurite.yaml down",
		"azurite:restart": "docker compose -f docker-compose.azurite.yaml restart",
		"azurite:logs": "docker compose -f docker-compose.azurite.yaml logs -f azurite",
		"azurite:status": "docker compose -f docker-compose.azurite.yaml ps",
		"setup": "npm install && npm run db:setup && npm run azurite:start",
		"reset": "npm run db:reset && npm run azurite:restart",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --no-file-parallelism --logHeapUsage",
		"test:e2e": "npx dotenv -e .env.local -- vitest run --config ./vitest.config.e2e.mts",
		"test:e2e:watch": "npx dotenv -e .env.local -- vitest --config ./vitest.config.e2e.mts",
		"test:e2e:setup": "npx dotenv -e .env.local -- npm run setup && npm run test:e2e",
		"test:e2e:reset": "npx dotenv -e .env.local -- npm run reset && npm run test:e2e",
		"open:docs": "npx open-cli http://localhost:3333/api/docs",
		"type-check": "tsc --noEmit",
		"validate-all": "npm run format && npm run type-check && npm run build && npm run test && npm run test:e2e",
		"start:fe-e2e": "npm run db:reset && npm run azurite:start && nest start --watch"
	},
	"dependencies": {
		"@azure/storage-blob": "^12.27.0",
		"@nestjs/axios": "^4.0.0",
		"@nestjs/common": "^11.0.15",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.15",
		"@nestjs/jwt": "^11.0.0",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.15",
		"@nestjs/swagger": "^11.1.1",
		"@prisma/client": "^6.16.3",
		"@thallesp/nestjs-better-auth": "^2.2.2",
		"axios": "^1.8.4",
		"better-auth": "1.4.15",
		"expo-server-sdk": "^3.15.0",
		"express": "^5.1.0",
		"graphql": "^16.12.0",
		"nestjs-zod": "^4.3.1",
		"nodemailer": "^7.0.6",
		"passport": "^0.7.0",
		"passport-custom": "^1.1.1",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"swagger-ui-express": "^5.0.1",
		"twilio": "^5.10.2",
		"zod": "^3.24.2",
		"zod-validation-error": "^3.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@faker-js/faker": "^9.6.0",
		"@nestjs/cli": "^11.0.6",
		"@nestjs/schematics": "^11.0.5",
		"@nestjs/testing": "^11.0.15",
		"@swc/cli": "^0.6.0",
		"@swc/core": "^1.11.18",
		"@types/express": "^5.0.1",
		"@types/multer": "^1.4.13",
		"@types/node": "^22.14.0",
		"@types/nodemailer": "^7.0.2",
		"@types/passport-jwt": "^4.0.1",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^3.1.1",
		"dotenv": "^16.4.7",
		"dotenv-cli": "^8.0.0",
		"lefthook": "^1.11.12",
		"open-cli": "^8.0.0",
		"prisma": "^6.16.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.1.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.8.3",
		"unplugin-swc": "^1.5.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.1.1"
	}
}
