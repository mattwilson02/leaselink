{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"allowImportingTsExtensions": true,
		"types": ["jest"],
		"paths": {
			"@/components/*": ["./src/components/*"],
			"@/hooks/*": ["./src/hooks/*"],
			"@/constants/*": ["./src/constants/*"],
			"@/utils/*": ["./src/utils/*"],
			"@/app/*": ["./app/*"],
			"@/assets/*": ["./assets/*"],
			"@/services/*": ["./src/services/*"],
			"@/gen/*": ["./src/gen/*"],
			"@/context/*": ["./src/context/*"],
			"@/atoms/*": ["./src/atoms/*"],
			"@/design-system/*": ["./src/design-system/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
