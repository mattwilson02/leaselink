{
  "name": "@leaselink/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "npx expo prebuild && npx expo run",
    "dev": "npx expo start -c",
    "android": "adb reverse tcp:3333 tcp:3333 && npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "prebuild": "npx expo prebuild --clean",
    "rebuild:android": "npx expo prebuild --clean && npm install && npx expo run:android",
    "rebuild:ios": "npx expo prebuild --clean && npm install && npx expo run:ios",
    "rebuild": "npx expo prebuild --clean && npm install",
    "rebuild:fresh": "rm -rf node_modules && npm install && npx expo prebuild --clean ",
    "rebuild:fresh:android": "rm -rf node_modules && npm install && npx expo prebuild --clean && npx expo run:android",
    "rebuild:fresh:ios": "rm -rf node_modules && npm install && npx expo prebuild --clean && npx expo run:ios",
    "test": "jest --watchAll",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e:ios": "./scripts/run-e2e-tests.sh ios",
    "test:e2e:android": "./scripts/run-e2e-tests.sh android",
    "codegen": "kubb generate",
    "lint": "npx @biomejs/biome check ./app ./src",
    "format": "npx @biomejs/biome format --write .",
    "json-server:dev": "npx json-server ./src/db.json --watch --port 3000",
    "json-server:stop": "npx kill-port 3000",
    "json-server:reset": "cp src/db-seed.json src/db.json",
    "snippets:refresh": "npx ts-node src/scripts/build-snippets.ts",
    "backend:start": "./scripts/run-backend.sh",
    "backend:stop": "docker-compose -f docker-compose.backend.yaml stop",
    "backend:restart": "docker-compose -f docker-compose.backend.yaml restart",
    "backend:down": "docker-compose -f docker-compose.backend.yaml down"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.5",
    "@config-plugins/react-native-blob-util": "^11.0.0",
    "@config-plugins/react-native-pdf": "^11.0.0",
    "@expo-google-fonts/lato": "^0.4.0",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@sf-digital-ui/react-native": "^2.6.0",
    "@sf-digital-ui/tokens": "^3.3.6",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-form": "^1.12.0",
    "@tanstack/react-query": "^5.77.2",
    "axios": "^1.9.0",
    "better-auth": "^1.5.5",
    "dayjs": "^1.11.13",
    "expo": "~53.0.23",
    "expo-auth-session": "~6.2.1",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.6",
    "expo-crypto": "^14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^13.1.6",
    "expo-file-system": "^18.1.11",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-manipulator": "~13.1.7",
    "expo-image-picker": "^16.1.4",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~16.0.5",
    "expo-localization": "~16.1.6",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.7",
    "expo-secure-store": "~14.2.4",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "~14.2.0",
    "i18next": "^25.2.1",
    "jotai": "^2.13.1",
    "json-server": "^1.0.0-beta.3",
    "lucide-react-native": "^0.514.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^15.5.2",
    "react-native": "0.79.5",
    "react-native-blob-util": "^0.22.2",
    "react-native-country-flag": "^2.0.2",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pdf": "^6.7.7",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.11.2",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "world-countries": "^5.1.0",
    "zod": "^4.0.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.27.3",
    "@biomejs/biome": "1.9.4",
    "@kubb/cli": "^3.10.12",
    "@kubb/core": "^3.10.12",
    "@kubb/plugin-client": "^3.10.12",
    "@kubb/plugin-react-query": "^3.10.12",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.10",
    "lefthook": "^1.11.13",
    "open-cli": "^8.0.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
