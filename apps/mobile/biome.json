{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			"node_modules",
			".expo",
			"ios",
			"android",
			".vscode",
			"src/gen",
			"package.json",
			"package-lock.json",
			"eas.json",
			"app.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"json": {
		"parser": { "allowComments": true },
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"organizeImports": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"suspicious": {
				"noSkippedTests": { "level": "warn", "fix": "none" },
				"noFocusedTests": {
					"level": "warn",
					"fix": "none"
				},
				"noExplicitAny": "error",
				"noEmptyInterface": "error",
				"noConsoleLog": {
					"level": "warn",
					"fix": "none"
				},
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "off"
			},
			"style": {
				"noYodaExpression": "error",
				"noVar": "error",
				"useNamingConvention": {
					"level": "error",
					"fix": "safe",
					"options": {
						"strictCase": false,
						"conventions": [
							{
								"selector": {
									"kind": "const",
									"scope": "global"
								},
								"formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
							},
							{
								"selector": {
									"kind": "const",
									"scope": "any"
								},
								"formats": ["camelCase"]
							},

							{
								"selector": {
									"kind": "enum",
									"scope": "any"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "function",
									"scope": "any"
								},
								"formats": ["camelCase", "PascalCase"]
							},
							{
								"selector": {
									"kind": "functionParameter",
									"scope": "any"
								},
								"formats": ["camelCase"]
							},
							{
								"selector": {
									"kind": "classMethod",
									"scope": "any"
								},
								"formats": ["camelCase"]
							},
							{
								"selector": {
									"kind": "classMember",
									"scope": "any"
								},
								"formats": ["camelCase"]
							},
							{
								"selector": {
									"kind": "interface",
									"scope": "any"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "typeAlias",
									"scope": "any"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "class",
									"scope": "any"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "objectLiteralProperty",
									"scope": "any"
								},
								"formats": ["camelCase", "snake_case", "PascalCase"]
							},
							{
								"selector": {
									"kind": "enumMember",
									"scope": "any"
								},
								"formats": ["CONSTANT_CASE"]
							}
						]
					}
				},
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["kebab-case"]
					}
				}
			},
			"complexity": {
				"useArrowFunction": "error"
			},
			"correctness": {
				"noUnusedImports": {
					"level": "warn",
					"fix": "none"
				},
				"noUnusedVariables": {
					"level": "warn",
					"fix": "none"
				},
				"noChildrenProp": "off"
			},
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"jsxQuoteStyle": "single"
		}
	}
}
